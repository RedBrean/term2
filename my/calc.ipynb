   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import pandas as pd\n",
    "\n",
    "d = 10**6 / 1200\n",
    "phi =  22.5 * np.pi / 180\n",
    "\n",
    "\n",
    "def theta(lamb,m=1):\n",
    "    s = (-m*lamb/d + np.sin(phi))\n",
    "    return np.arcsin(s)\n",
    "\n",
    "xl = np.linspace(780, 810, 100)\n",
    "plt.plot(xl, theta(xl)*180/np.pi)\n"
   ]
  }
 ],
